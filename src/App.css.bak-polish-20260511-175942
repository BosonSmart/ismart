* {
  box-sizing: border-box;
}

:root {
  color-scheme: dark;
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  background: #020617;
  color: #f8fafc;
  line-height: 1.5;
}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  min-width: 320px;
  background: #020617;
}

a {
  color: inherit;
  text-decoration: none;
}

button {
  font: inherit;
}

.site {
  min-height: 100vh;
  position: relative;
  overflow-x: hidden;
}

.glow {
  position: fixed;
  pointer-events: none;
  border-radius: 999px;
  filter: blur(72px);
  opacity: 0.65;
  z-index: 0;
}

.glow-one {
  width: 32rem;
  height: 32rem;
  left: 50%;
  top: -12rem;
  transform: translateX(-50%);
  background: rgba(34, 211, 238, 0.22);
}

.glow-two {
  width: 28rem;
  height: 28rem;
  right: -10rem;
  bottom: -6rem;
  background: rgba(37, 99, 235, 0.2);
}

.nav,
main,
footer {
  position: relative;
  z-index: 1;
}

.nav {
  position: sticky;
  top: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1.25rem;
  padding: 1rem max(1.25rem, calc((100vw - 1180px) / 2));
  background: rgba(2, 6, 23, 0.82);
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(18px);
}

.brand {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  min-width: max-content;
}

.brand strong {
  display: block;
  font-size: 1.08rem;
}

.brand small {
  display: block;
  color: #94a3b8;
  font-size: 0.76rem;
}

.brand-mark,
.large-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #67e8f9;
  color: #020617;
  width: 2.65rem;
  height: 2.65rem;
  border-radius: 1rem;
  box-shadow: 0 12px 36px rgba(34, 211, 238, 0.22);
}

.icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.desktop-nav,
.nav-actions,
footer nav {
  display: flex;
  align-items: center;
  gap: 1.45rem;
}

.desktop-nav a,
footer a {
  color: #cbd5e1;
  font-size: 0.92rem;
  transition: 0.2s;
}

.desktop-nav a:hover,
footer a:hover {
  color: #ffffff;
}

.language-toggle {
  display: inline-flex;
  padding: 0.2rem;
  gap: 0.15rem;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,0.12);
  background: rgba(255,255,255,0.04);
}

.language-toggle button {
  border: 0;
  border-radius: 999px;
  background: transparent;
  color: #cbd5e1;
  padding: 0.45rem 0.75rem;
  cursor: pointer;
  font-weight: 700;
  font-size: 0.78rem;
}

.language-toggle button.active {
  background: #67e8f9;
  color: #020617;
}

.menu-button {
  display: none;
  border: 1px solid rgba(255,255,255,0.12);
  background: transparent;
  color: white;
  border-radius: 0.8rem;
  padding: 0.55rem 0.7rem;
  cursor: pointer;
}

.mobile-menu {
  position: absolute;
  left: 1rem;
  right: 1rem;
  top: calc(100% + 0.5rem);
  display: grid;
  gap: 0.85rem;
  padding: 1rem;
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 1.2rem;
  background: rgba(15, 23, 42, 0.98);
  box-shadow: 0 24px 60px rgba(0,0,0,0.36);
}

.mobile-menu a {
  color: #cbd5e1;
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.45rem;
  border-radius: 999px;
  padding: 0.82rem 1.25rem;
  font-weight: 750;
  transition: 0.2s ease;
  border: 1px solid transparent;
}

.pill.white {
  background: white;
  color: #020617;
  padding: 0.65rem 1.05rem;
}

.pill.cyan {
  background: #22d3ee;
  color: #020617;
  box-shadow: 0 14px 32px rgba(34, 211, 238, 0.22);
}

.pill.cyan:hover {
  background: #67e8f9;
}

.pill.ghost {
  border-color: rgba(255,255,255,0.16);
  color: white;
}

.pill.ghost:hover {
  background: rgba(255,255,255,0.08);
}

.pill.dark {
  background: #020617;
  color: white;
}

.pill.outline-dark {
  border-color: rgba(2,6,23,0.25);
  color: #020617;
}

.pill.full {
  width: 100%;
}

.hero,
.section,
footer {
  max-width: 1180px;
  margin: 0 auto;
  padding: 4.8rem 1.25rem;
}

.hero {
  display: grid;
  grid-template-columns: 1.08fr 0.92fr;
  gap: 3rem;
  align-items: center;
}

.eyebrow,
.contact-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 0.45rem;
  margin-bottom: 1rem;
  color: #67e8f9;
  text-transform: uppercase;
  letter-spacing: 0.18em;
  font-weight: 800;
  font-size: 0.78rem;
}

.hero .eyebrow {
  border: 1px solid rgba(103, 232, 249, 0.22);
  background: rgba(103, 232, 249, 0.09);
  border-radius: 999px;
  padding: 0.55rem 0.9rem;
  text-transform: none;
  letter-spacing: 0;
}

h1,
h2,
h3,
p {
  margin-top: 0;
}

h1 {
  margin-bottom: 1.25rem;
  font-size: clamp(3.2rem, 7vw, 5.9rem);
  line-height: 0.95;
  letter-spacing: -0.055em;
}

h2 {
  margin-bottom: 1rem;
  font-size: clamp(2.1rem, 4.5vw, 3.85rem);
  line-height: 1.02;
  letter-spacing: -0.045em;
}

h3 {
  margin-bottom: 0.65rem;
}

p {
  color: #cbd5e1;
}

.lead {
  max-width: 44rem;
  font-size: 1.15rem;
  line-height: 1.8;
}

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.8rem;
  margin: 2rem 0 2.25rem;
}

.trust-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.8rem;
}

.trust-card,
.mini-card,
.info-card,
.panel,
.why-card,
.builder-panel,
.comparison-card,
.selected-layout,
.process-step,
.dashboard-card,
.package-card,
.choice {
  border: 1px solid rgba(255,255,255,0.1);
  background: rgba(255,255,255,0.04);
  border-radius: 1.5rem;
}

.trust-card {
  display: flex;
  gap: 0.6rem;
  padding: 1rem;
  color: #cbd5e1;
  font-size: 0.92rem;
}

.check-icon {
  color: #67e8f9;
  flex: 0 0 auto;
}

.dashboard-card {
  padding: 1rem;
  border-radius: 2rem;
  box-shadow: 0 24px 70px rgba(0,0,0,0.36);
  backdrop-filter: blur(20px);
}

.dashboard-inner {
  padding: 1.35rem;
  border-radius: 1.5rem;
  background: #0f172a;
}

.dashboard-head {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: 1.2rem;
}

.dashboard-head small,
.dashboard-row small {
  display: block;
  color: #94a3b8;
}

.dashboard-head strong {
  display: block;
  font-size: 1.5rem;
}

.dashboard-head > span {
  align-self: start;
  padding: 0.28rem 0.7rem;
  border-radius: 999px;
  color: #bbf7d0;
  background: rgba(34,197,94,0.12);
  font-size: 0.88rem;
}

.dashboard-list {
  display: grid;
  gap: 0.85rem;
}

.dashboard-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  border: 1px solid rgba(255,255,255,0.08);
  background: rgba(255,255,255,0.04);
  border-radius: 1.25rem;
  padding: 1rem;
}

.dashboard-row em {
  font-style: normal;
  color: #cffafe;
  background: rgba(255,255,255,0.08);
  border-radius: 0.75rem;
  padding: 0.48rem 0.7rem;
}

.section-header {
  display: flex;
  align-items: end;
  justify-content: space-between;
  gap: 2rem;
  margin-bottom: 2rem;
}

.section-header > div:first-child {
  max-width: 48rem;
}

.note-box {
  max-width: 28rem;
  border: 1px solid rgba(255,255,255,0.1);
  background: rgba(255,255,255,0.04);
  border-radius: 1.25rem;
  color: #cbd5e1;
  padding: 1rem;
  font-size: 0.92rem;
}

.package-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
}

.package-card,
.choice {
  color: white;
  cursor: pointer;
  text-align: left;
  padding: 1.35rem;
  transition: 0.2s ease;
}

.package-card:hover,
.choice:hover {
  border-color: rgba(255,255,255,0.26);
  transform: translateY(-2px);
}

.package-card.active,
.choice.active {
  border-color: rgba(103, 232, 249, 0.8);
  background: rgba(103, 232, 249, 0.1);
  box-shadow: 0 18px 44px rgba(34,211,238,0.1);
}

.card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: 1.2rem;
}

.large-icon {
  width: 3.3rem;
  height: 3.3rem;
  color: #cffafe;
  background: rgba(255,255,255,0.08);
  font-size: 1.4rem;
  box-shadow: none;
}

.tag {
  border: 1px solid rgba(255,255,255,0.1);
  color: #cbd5e1;
  border-radius: 999px;
  padding: 0.32rem 0.65rem;
  font-size: 0.78rem;
}

.cyan-text {
  color: #cffafe;
}

.price {
  display: block;
  margin: 1rem 0;
  font-size: 1.45rem;
}

ul {
  list-style: none;
  margin: 1rem 0 0;
  padding: 0;
  display: grid;
  gap: 0.65rem;
}

li {
  display: flex;
  gap: 0.55rem;
  color: #cbd5e1;
  font-size: 0.92rem;
}

.select-label {
  display: inline-flex;
  gap: 0.45rem;
  margin-top: 1.2rem;
  color: #67e8f9;
  font-weight: 800;
}

.builder-layout {
  display: grid;
  grid-template-columns: 1fr 380px;
  gap: 1.2rem;
  align-items: start;
}

.builder-main,
.stack,
.process-list {
  display: grid;
  gap: 1rem;
}

.builder-panel {
  padding: 1.35rem;
  border-radius: 2rem;
}

.choice-grid {
  display: grid;
  gap: 0.9rem;
}

.choice-grid.three {
  grid-template-columns: repeat(3, 1fr);
}

.choice-grid.two,
.card-grid.two {
  grid-template-columns: repeat(2, 1fr);
}

.choice {
  display: grid;
  gap: 0.65rem;
}

.choice small {
  color: #94a3b8;
}

.choice em {
  color: #cffafe;
  font-style: normal;
  font-weight: 800;
}

.row-choice {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 1rem;
}

.row-choice strong {
  display: flex;
  gap: 0.5rem;
  align-items: center;
}

.row-choice small {
  display: block;
  margin-top: 0.25rem;
}

.round-select {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 1.25rem;
  height: 1.25rem;
  border-radius: 999px;
  background: rgba(255,255,255,0.1);
  color: #67e8f9;
  font-size: 0.78rem;
}

.choice.active .round-select {
  background: #67e8f9;
  color: #020617;
}

.estimate-card {
  position: sticky;
  top: 6.4rem;
  border: 1px solid rgba(103,232,249,0.3);
  border-radius: 2rem;
  background: rgba(15, 23, 42, 0.96);
  padding: 1.35rem;
  box-shadow: 0 24px 70px rgba(0,0,0,0.36);
  backdrop-filter: blur(18px);
}

.estimate-head {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  border-bottom: 1px solid rgba(255,255,255,0.1);
  padding-bottom: 1.2rem;
}

.estimate-head small {
  color: #67e8f9;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  font-weight: 800;
  font-size: 0.72rem;
}

.estimate-head strong {
  display: block;
  margin-top: 0.4rem;
  font-size: 2rem;
}

.estimate-lines {
  display: grid;
  gap: 1rem;
  padding: 1rem 0;
}

.summary-line {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
}

.summary-line > span,
.summary-block > span {
  color: #94a3b8;
}

.summary-line strong {
  text-align: right;
}

.summary-line small {
  display: block;
  color: #cbd5e1;
  font-weight: 500;
}

.addon-line {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  border-radius: 1rem;
  background: rgba(255,255,255,0.04);
  padding: 0.55rem 0.7rem;
  margin-top: 0.45rem;
}

.addon-line em {
  color: #cffafe;
  font-style: normal;
}

.muted {
  color: #94a3b8;
}

.total-box {
  background: rgba(103,232,249,0.1);
  border-radius: 1.2rem;
  padding: 1rem;
}

.total-box small {
  color: #cffafe;
}

.total-box strong {
  display: block;
  margin-top: 0.15rem;
  font-size: 2.3rem;
}

.fine-print {
  color: #94a3b8;
  font-size: 0.78rem;
  line-height: 1.65;
  margin: 1rem 0;
}

.selected-layout,
.split-section,
.process-section,
.previsit-section {
  display: grid;
  grid-template-columns: 0.9fr 1.1fr;
  gap: 1.5rem;
  align-items: start;
}

.selected-layout,
.why-card,
.panel,
.comparison-card {
  padding: 1.5rem;
  border-radius: 2rem;
}

.soft-box {
  margin-top: 1.25rem;
  border-radius: 1.1rem;
  background: rgba(255,255,255,0.05);
  color: #cbd5e1;
  padding: 1rem;
}

.feature-grid,
.card-grid {
  display: grid;
  gap: 0.8rem;
}

.feature-grid {
  grid-template-columns: repeat(2, 1fr);
}

.mini-card {
  display: flex;
  align-items: flex-start;
  gap: 0.6rem;
  padding: 0.9rem;
  color: #cbd5e1;
  font-size: 0.92rem;
}

.highlighted {
  border-color: rgba(103,232,249,0.24);
  background: rgba(103,232,249,0.08);
}

.warning-dot {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  width: 1rem;
  height: 1rem;
  border-radius: 999px;
  background: rgba(255,255,255,0.1);
  color: #cbd5e1;
  font-size: 0.65rem;
}

.scenario-row {
  display: flex;
  gap: 1rem;
  overflow-x: auto;
  padding-bottom: 0.5rem;
}

.scenario-card {
  min-width: 15.5rem;
  border: 1px solid rgba(255,255,255,0.1);
  background: rgba(255,255,255,0.04);
  border-radius: 1.5rem;
  padding: 1.25rem;
  transition: 0.2s;
}

.scenario-card:hover {
  transform: translateY(-2px);
  border-color: rgba(103,232,249,0.3);
}

.scenario-card > div {
  display: flex;
  justify-content: space-between;
  color: #67e8f9;
}

.scenario-card > div span {
  background: rgba(103,232,249,0.1);
  border-radius: 999px;
  padding: 0.28rem 0.65rem;
  color: #cffafe;
  font-size: 0.85rem;
}

.comparison-card h2 {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  font-size: 2rem;
}

.table-wrap {
  overflow-x: auto;
}

table {
  width: 100%;
  border-spacing: 0 0.7rem;
  min-width: 740px;
}

th,
td {
  text-align: left;
  padding: 1rem;
}

th {
  color: #94a3b8;
  font-weight: 700;
}

td {
  background: rgba(15,23,42,0.82);
  color: #cbd5e1;
}

td:first-child {
  color: white;
  border-radius: 1rem 0 0 1rem;
}

td:last-child {
  border-radius: 0 1rem 1rem 0;
}

.process-step {
  display: flex;
  gap: 1rem;
  align-items: center;
  padding: 1rem;
}

.process-step span {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 2.4rem;
  height: 2.4rem;
  border-radius: 0.9rem;
  background: #67e8f9;
  color: #020617;
  font-weight: 900;
}

.info-card {
  padding: 1.25rem;
}

.info-card > .icon {
  width: 2.4rem;
  height: 2.4rem;
  margin-bottom: 1rem;
  border-radius: 0.9rem;
  background: rgba(103,232,249,0.1);
  color: #67e8f9;
}

.contact-card {
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: 2rem;
  align-items: center;
  border-radius: 2rem;
  background: #67e8f9;
  color: #020617;
  padding: 2rem;
}

.contact-card p {
  color: #0f172a;
}

.contact-card h2 {
  color: #020617;
}

.contact-eyebrow {
  color: #0f172a;
  background: rgba(2,6,23,0.1);
  border-radius: 999px;
  padding: 0.45rem 0.8rem;
  letter-spacing: 0;
  text-transform: none;
}

.contact-actions {
  display: grid;
  gap: 0.8rem;
}

footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
  border-top: 1px solid rgba(255,255,255,0.1);
  color: #94a3b8;
  padding-top: 2rem;
  padding-bottom: 2rem;
}

@media (max-width: 980px) {
  .desktop-nav,
  .nav-actions {
    display: none;
  }

  .menu-button {
    display: inline-flex;
  }

  .hero,
  .builder-layout,
  .selected-layout,
  .split-section,
  .process-section,
  .previsit-section,
  .contact-card {
    grid-template-columns: 1fr;
  }

  .package-grid,
  .choice-grid.three,
  .choice-grid.two,
  .feature-grid,
  .card-grid.two,
  .trust-grid {
    grid-template-columns: 1fr;
  }

  .section-header {
    display: block;
  }

  .note-box {
    margin-top: 1rem;
  }

  .estimate-card {
    position: static;
  }

  h1 {
    font-size: clamp(3rem, 13vw, 4.6rem);
  }
}

@media (max-width: 620px) {
  .hero,
  .section,
  footer {
    padding-left: 1rem;
    padding-right: 1rem;
  }

  .nav {
    padding-left: 1rem;
    padding-right: 1rem;
  }

  .brand small {
    display: none;
  }

  .row-choice,
  .summary-line,
  .dashboard-row {
    align-items: flex-start;
    flex-direction: column;
  }

  .summary-line strong {
    text-align: left;
  }

  .contact-card,
  .builder-panel,
  .selected-layout,
  .panel,
  .why-card,
  .comparison-card {
    padding: 1.15rem;
  }

  footer {
    align-items: flex-start;
    flex-direction: column;
  }
}

.launch-card {
  border: 1px solid rgba(103, 232, 249, 0.22);
  background:
    radial-gradient(circle at top left, rgba(103, 232, 249, 0.18), transparent 34rem),
    rgba(255, 255, 255, 0.045);
  border-radius: 2rem;
  padding: 2rem;
  box-shadow: 0 24px 70px rgba(0, 0, 0, 0.28);
}

.launch-layout {
  display: grid;
  grid-template-columns: 1fr 360px;
  gap: 2rem;
  align-items: start;
}

.launch-side {
  border: 1px solid rgba(255, 255, 255, 0.1);
  background: rgba(2, 6, 23, 0.45);
  border-radius: 1.5rem;
  padding: 1.25rem;
}

.launch-badge {
  display: inline-flex;
  margin-bottom: 1rem;
  border-radius: 999px;
  background: rgba(103, 232, 249, 0.14);
  color: #cffafe;
  padding: 0.45rem 0.8rem;
  font-weight: 800;
  font-size: 0.85rem;
}

.launch-points {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0.9rem;
  margin-top: 1.75rem;
}

.launch-point {
  border: 1px solid rgba(255, 255, 255, 0.1);
  background: rgba(15, 23, 42, 0.72);
  border-radius: 1.35rem;
  padding: 1rem;
}

.launch-number {
  display: inline-flex;
  margin-bottom: 0.85rem;
  border-radius: 999px;
  background: #67e8f9;
  color: #020617;
  padding: 0.25rem 0.6rem;
  font-weight: 900;
  font-size: 0.8rem;
}

.launch-point h3 {
  font-size: 1.05rem;
}

.launch-point p {
