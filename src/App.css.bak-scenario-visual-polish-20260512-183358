@import "tailwindcss";

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  min-width: 320px;
  background: #020617;
  color: #ffffff;
}

#root {
  min-height: 100vh;
}

* {
  box-sizing: border-box;
}

button,
a {
  -webkit-tap-highlight-color: transparent;
  cursor: pointer;
}

button {
  font: inherit;
}

button:focus-visible,
a:focus-visible {
  outline: 2px solid #67e8f9;
  outline-offset: 3px;
}

.btn-primary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  border-radius: 999px;
  background: #67e8f9;
  color: #020617;
  padding: 0.75rem 1.5rem;
  font-weight: 750;
  box-shadow: 0 16px 40px rgba(103, 232, 249, 0.16);
  transition: 0.2s ease;
}

.btn-primary:hover {
  background: #a5f3fc;
}

.btn-secondary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,0.16);
  color: white;
  padding: 0.75rem 1.5rem;
  font-weight: 750;
  transition: 0.2s ease;
}

.btn-secondary:hover {
  background: rgba(255,255,255,0.08);
}

@media (prefers-reduced-motion: reduce) {
  html {
    scroll-behavior: auto;
  }

  *,
  *::before,
  *::after {
    animation-duration: 0.001ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.001ms !important;
  }
}


/* v2.1 simplified scene timeline */
@supports (backdrop-filter: blur(8px)) {
  .scene-glass {
    backdrop-filter: blur(12px);
  }
}


/* full-page scenario snap scroll */
.fullpage-scenario-scroll {
  scrollbar-width: none;
  -ms-overflow-style: none;
}

.fullpage-scenario-scroll::-webkit-scrollbar {
  display: none;
}

@supports (height: 100dvh) {
  .fullpage-scenario-scroll {
    height: calc(100dvh - 4.25rem);
  }
}
